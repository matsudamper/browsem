{
  "manifest_version": 2,
  "name": "Theme Color Bridge",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "theme-color-bridge@browsem"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["nativeMessaging"]
}
