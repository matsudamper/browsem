{
  "permissions": {
    "allow": [
      "Bash(./gradlew:*)",
      "Bash(unzip:*)",
      "Bash(git:log:*)",
      "Bash(git:diff:*)",
      "Bash(git:mv:*)",
      "Bash(git:show:*)",
      "Bash(xargs grep:*)",
      "Read(./**)",
      "mcp__ide__getDiagnostics"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
